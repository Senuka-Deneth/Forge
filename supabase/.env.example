# Copy to `.env` for local `supabase functions serve` (never commit real secrets).
#
# --- Required for Edge Functions that talk to Postgres ---
# Project URL (Dashboard → Project Settings → API → Project URL)
SUPABASE_URL=
# service_role key (Dashboard → Project Settings → API) — server-side only
SUPABASE_SERVICE_ROLE_KEY=
#
# Used by get-market-data to cache candles in public.market_cache (TTL in seconds, 30–86400).
MARKET_CACHE_TTL_SECONDS=300
#
# --- CORS ---
# Comma-separated list of exact frontend origins allowed to call these functions
# (e.g. https://app.example.com,http://localhost:5173). Defaults to localhost:5173 if unset.
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
#
# --- ai-analysis function ---
OPENROUTER_API_KEY=
OPENROUTER_HTTP_REFERER=
# Optional: override the OpenRouter model id (defaults to nvidia/nemotron-super-49b-v1:free).
# A stronger model materially improves the quality of the generated trade plan and reasoning.
OPENROUTER_MODEL=
